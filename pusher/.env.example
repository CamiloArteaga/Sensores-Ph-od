# Copia este archivo a .env y rellena los valores
# En Windows: COM3   |   En Raspberry Pi: /dev/ttyUSB0
SERIAL_PORT=COM3

# URL del backend en Railway (sin slash al final)
CLOUD_URL=https://tu-app.railway.app

# ID único para esta piscina — cada RPi tiene el suyo
DEVICE_ID=pH_DO_1

# Misma clave que configures en Railway → Variables → API_KEY
API_KEY=cambia-esto-por-una-clave-secreta

# Cada cuántos segundos se revisan comandos pendientes
POLL_INTERVAL=2
